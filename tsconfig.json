{
  "compilerOptions": {
    "target": "ES2018",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@auth/*": [
        "./src/auth/*"
      ],
      "@account/*": [
        "./src/account/*"
      ],
      "@actions/*": [
        "./src/actions/*"
      ],
      "@lib/*": [
        "./src/lib/*"
      ],
      "@brag/*": [
        "./src/features/brag/*"
      ],
      "@landing/*": [
        "./src/app/(public)/landing/*"
      ],
      "@mfa/*": [
        "./src/features/mfa/*"
      ],
      "@feedback/*": [
        "./src/features/feedback/*"
      ],
      "@linkedin/*": [
        "./src/features/linkedin/*"
      ],
      "@resume/*": [
        "./src/features/resume/*"
      ],
      "@signup/*": [
        "./src/features/signup/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@api/*": [
        "./src/app/api/*"
      ]
    }
  },
  "include": [
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
